# Copie para .env e ajuste. O .env é lido automaticamente pelo docker compose.
# Os valores abaixo são defaults de desenvolvimento — NÃO use em produção.

# PostgreSQL / PostGIS
POSTGRES_DB=dimap_geocode
POSTGRES_USER=dimap
POSTGRES_PASSWORD=dimap
DB_PORT=5432

# Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_AUTO_MIGRATE=1
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me
WEB_PORT=8000
